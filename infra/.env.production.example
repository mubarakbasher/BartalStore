# ============ Bartal — per-port test (.env.production) ============
# Copy to infra/.env.production, fill VPS_IP + secrets, then deploy. Do NOT commit the filled file.

# --- Ports (each surface its own; move any that clash with the neighbor app) ---
WEB_HTTP_PORT=8080
API_HTTP_PORT=8081
ADMIN_HTTP_PORT=8082
VPS_IP=__YOUR_VPS_IP__              # used by CORS, baked URLs, and the optional web extra_hosts

# --- Postgres (internal-only; service name = DNS host) ---
POSTGRES_USER=bartal
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__
POSTGRES_DB=bartal_test
DATABASE_URL=postgresql://bartal:__CHANGE_ME_STRONG__@postgres:5432/bartal_test?schema=public

# --- Redis (internal-only) ---
REDIS_URL=redis://redis:6379

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=production
# CROSS-ORIGIN: browser calls come from the web + admin origins → list BOTH exactly
# (credentials:true forbids "*"). Substitute the real IP[:port].
CORS_ORIGINS=http://__YOUR_VPS_IP__:8080,http://__YOUR_VPS_IP__:8082
# Only honored if you applied the apps/web/src/middleware.ts edit; lets HTTP keep auth cookies.
COOKIE_SECURE=false

# --- Auth (generate fresh: `openssl rand -hex 32`) ---
JWT_ACCESS_SECRET=__GENERATE__
JWT_REFRESH_SECRET=__GENERATE__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# --- OTP / rate limiting (defaults are fine for a test) ---
OTP_TTL_SECONDS=600
OTP_MAX_PER_WINDOW=5
OTP_WINDOW_SECONDS=900

# --- Seed admin (MUST change before exposing the admin port — it's publicly reachable) ---
SEED_ADMIN_PHONE=+249912000001
SEED_ADMIN_PASSWORD=__CHANGE_ME_BEFORE_EXPOSING__
SEED_ADMIN_NAME=Bartal Admin
SEED_ADMIN_EMAIL=admin@bartal.sd
# Demo catalogue: false = empty storefront (admin + delivery zones + store settings still seeded).
# Set true to load the ~20 sample products + 6 categories instead.
SEED_DEMO_DATA=false

# --- Baked into web + admin at BUILD time → point at the API's OWN port ---
NEXT_PUBLIC_API_BASE_URL=http://__YOUR_VPS_IP__:8081/api
NEXT_PUBLIC_SITE_URL=http://__YOUR_VPS_IP__:8080

# --- External services: leave BLANK → graceful stub / no-op (boot never blocks on them) ---
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=BARTAL
FCM_SERVICE_ACCOUNT_PATH=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=bartal-public
R2_BUCKET_RECEIPTS=bartal-receipts
R2_PUBLIC_URL_BASE=https://assets.bartal.sd

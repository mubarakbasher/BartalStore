# =============================================================================
# Bartal — Root environment template
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Database -----------------------------------------------------------------
POSTGRES_USER=bartal
POSTGRES_PASSWORD=bartal_dev_pw
POSTGRES_DB=bartal_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bartal:bartal_dev_pw@localhost:5432/bartal_dev?schema=public

# --- Redis --------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API server ---------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Auth (JWT) ---------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# --- OTP / rate limiting ------------------------------------------------------
OTP_TTL_SECONDS=600
OTP_MAX_PER_WINDOW=5
OTP_WINDOW_SECONDS=900

# --- SMS (Africa's Talking) ---------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=BARTAL

# --- Push (Firebase Cloud Messaging) ------------------------------------------
# Path to the FCM service account JSON file (e.g. ./firebase-service-account.json)
FCM_SERVICE_ACCOUNT_PATH=

# --- File storage (Cloudflare R2 — S3-compatible) -----------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=bartal-public
R2_BUCKET_RECEIPTS=bartal-receipts
R2_PUBLIC_URL_BASE=https://assets.bartal.sd

# --- Store / merchant info (shown to customers at checkout) -------------------
STORE_NAME_AR=بَرتال
STORE_NAME_EN=Bartal
STORE_BANK_NAME_AR=بنك الخرطوم
STORE_BANK_NAME_EN=Bank of Khartoum
STORE_BANK_ACCOUNT_NAME=Bartal Trading
STORE_BANK_ACCOUNT_NUMBER=0000-0000-0000-0000
WHATSAPP_SUPPORT_NUMBER=+249912345678

# --- Admin seed (only used by prisma:seed) ------------------------------------
SEED_ADMIN_EMAIL=admin@bartal.sd
SEED_ADMIN_PHONE=+249912000001
SEED_ADMIN_NAME=Bartal Admin
SEED_ADMIN_PASSWORD=ChangeMe123!
